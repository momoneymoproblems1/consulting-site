# Resend API key. Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Resend audience ID for the newsletter. Create an audience named "Newsletter"
# at https://resend.com/audiences and paste its ID here.
RESEND_AUDIENCE_ID=

# Where contact form submissions are emailed.
CONTACT_TO_EMAIL=drewgood27@gmail.com

# Cal.com username, e.g. "andrew-gooding" gives https://cal.com/andrew-gooding
NEXT_PUBLIC_CAL_USERNAME=

# PostHog Project API key (Settings > Project > Project API Key, starts with "phc_")
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingestion host. US cloud: https://us.i.posthog.com  /  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=
